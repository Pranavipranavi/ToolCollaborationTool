# Local server runtime
PORT=5000
NODE_ENV=development
CLIENT_URL=http://localhost:5173
SERVER_URL=http://localhost:5000

# Render production values:
# NODE_ENV=production
# CLIENT_URL=https://your-taskflow-app.vercel.app
# SERVER_URL=https://task-collaboration-tool.onrender.com

# MongoDB Atlas connection string. Required for real persistence/auth/workspaces/tasks.
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/taskflow

# JWT signing. Required for auth; use a long random value.
JWT_SECRET=replace-with-a-long-random-secret-at-least-32-characters
JWT_EXPIRES_IN=7d

# OAuth. Optional for local email/password auth, required for production Google login.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
